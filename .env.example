# Copy to .env and fill in real values (git does NOT update your .env automatically)
# After editing .env — restart uvicorn

APP_NAME=Status Check
DEBUG=true

# SQLite database file
DATABASE_URL=sqlite:///./status_check.db

# Secret for JWT (use a long random string in production)
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
