# Скопіюйте в .env і заповніть реальними значеннями (git не оновлює .env автоматично)
# Після змін у .env — перезапустіть uvicorn

APP_NAME=Status Check
DEBUG=true

# Файл бази SQLite
DATABASE_URL=sqlite:///./status_check.db

# Секрет для JWT (у production — довгий випадковий рядок)
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Продакшен (Docker / Render)
SERVE_FRONTEND=false
CORS_ORIGINS=
SEED_ON_STARTUP=false
